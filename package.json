{
  "name": "pic4paws-v2",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "npm@10.9.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "overrides": {
    "@expo/metro-config": {
      "postcss": "8.5.15"
    },
    "next": {
      "postcss": "8.5.15"
    },
    "xcode": {
      "uuid": "11.1.1"
    }
  },
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck && npx tsc --noEmit -p tests/tsconfig.json",
    "check:sdd-work-items": "node scripts/check-work-items.mjs",
    "lint": "turbo run lint && eslint . && npm run check:sdd-work-items",
    "test": "turbo run test && vitest run",
    "format": "prettier --write .",
    "db:generate-migrations": "npx --yes tsx scripts/generate-migrations.ts"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^20.19.0",
    "@typescript-eslint/eslint-plugin": "^8.48.0",
    "@typescript-eslint/parser": "^8.48.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.6.2",
    "turbo": "^2.6.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.48.0",
    "vitest": "^4.0.15"
  }
}
