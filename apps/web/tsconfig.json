{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "jsx": "preserve",
    "outDir": "dist-types",
    "types": [
      "node"
    ],
    "paths": {
      "@pic4paws/domain": [
        "../../packages/domain/src/index.ts"
      ],
      "@pic4paws/client": [
        "../../packages/client/src/index.ts"
      ],
      "@pic4paws/ui": [
        "../../packages/ui/src/index.ts"
      ]
    },
    "noEmit": true,
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "app/**/*.ts",
    "app/**/*.tsx",
    "next-env.d.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "references": [
    {
      "path": "../../packages/domain"
    },
    {
      "path": "../../packages/client"
    },
    {
      "path": "../../packages/ui"
    }
  ],
  "exclude": [
    "node_modules"
  ]
}
