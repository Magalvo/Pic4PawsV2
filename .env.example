# Pic4Paws V2 local development example.
# Copy to .env on each machine and replace placeholders with local/dev credentials only.
# Never commit real secrets.

APP_ENV=development
PUBLIC_APP_ORIGIN=http://localhost:3000

# Web app — Next.js (NEXT_PUBLIC_ prefix exposes to browser)
NEXT_PUBLIC_WORKER_URL=http://localhost:8787
NEXT_PUBLIC_WORKER_MEDIA_URL_PATH=/media
NEXT_PUBLIC_SUPABASE_URL=https://example.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-dev-anon-key

SUPABASE_URL=https://example.supabase.co
SUPABASE_ANON_KEY=replace-with-dev-anon-key
SUPABASE_SERVICE_ROLE_KEY=replace-with-dev-service-role-key

CLOUDFLARE_ACCOUNT_ID=replace-with-dev-cloudflare-account-id
R2_PUBLIC_BUCKET=pic4paws-public-dev
R2_PRIVATE_BUCKET=pic4paws-private-dev
R2_ACCESS_KEY_ID=replace-with-dev-r2-access-key-id
R2_SECRET_ACCESS_KEY=replace-with-dev-r2-secret-access-key

WORKER_PAYMENT_WEBHOOK_PATH=/webhooks/payments
WORKER_MEDIA_UPLOAD_PATH=/uploads/media
WORKER_PET_DRAFTS_PATH=/pets/drafts

PAYMENT_PRIMARY_PROVIDER=stripe
EUPAGO_API_KEY=
EUPAGO_WEBHOOK_SECRET=
IFTHENPAY_MB_KEY=
IFTHENPAY_MBWAY_KEY=
IFTHENPAY_WEBHOOK_SECRET=
STRIPE_SECRET_KEY=replace-with-dev-stripe-secret-key
STRIPE_WEBHOOK_SECRET=replace-with-dev-stripe-webhook-secret

# Mobile app — Expo (EXPO_PUBLIC_ prefix exposes to client bundle)
EXPO_PUBLIC_WORKER_URL=http://localhost:8787
EXPO_PUBLIC_WORKER_MEDIA_URL_PATH=/media
EXPO_PUBLIC_SUPABASE_URL=https://example.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=replace-with-dev-anon-key
